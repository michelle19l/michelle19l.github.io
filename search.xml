</tr>
<tr>
<td>00401036   push        ebx</td>
<td><strong>00401036</strong></td>
<td><strong>0012FEDC</strong></td>
<td></td>
</tr>
<tr>
<td>00401037   push        esi</td>
<td><strong>00401037</strong></td>
<td><strong>0012FED8</strong></td>
<td></td>
</tr>
<tr>
<td>00401038   push        edi</td>
