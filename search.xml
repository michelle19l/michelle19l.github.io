<td><strong>0012FF24</strong></td>
<td>0012FF80</td>
</tr>
<tr>
<td>00401031   mov         ebp,esp</td>
<td><strong>00401031</strong></td>
<td><strong>0012FF20</strong></td>
<td></td>
</tr>
<tr>
<td>00401033   sub         esp,44h</td>
<td><strong>00401033</strong></td>
<td></td>
